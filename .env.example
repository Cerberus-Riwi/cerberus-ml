# PostgreSQL
PGHOST=localhost
PGPORT=5432
PGDATABASE=cerberus
PGUSER=cerberus
PGPASSWORD=tu-contraseña-aqui

# RabbitMQ
RABBITMQ_HOST=164.68.108.39
RABBITMQ_PORT=5672
RABBITMQ_USER=xxxxxxxx
RABBITMQ_PASSWORD=xxxxxxxx

# Airflow — usadas por consumer/rabbit_consumer.py para disparar el DAG
# cerberus_etl vía la REST API, y por docker-compose.yml para crear el
# usuario admin de Airflow.
AIRFLOW_BASE_URL=http://airflow-webserver:8080
AIRFLOW_ETL_DAG_ID=cerberus_etl
AIRFLOW_API_USER=admin
AIRFLOW_API_PASSWORD=cambia-esta-contraseña